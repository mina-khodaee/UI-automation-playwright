{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "start": {
      "dependsOn": [
        "build"
      ]
    },
    "build": {
      "passThroughEnv": [
        "PLAYWRIGHT_*",
        "NEXT_PUBLIC_*"
      ],
      "env": [
        "NODE_ENV",
        "BUILD_STATIC_EXPORT"
      ],
      "dependsOn": [
        "^build",
        "lint",
        "check-types"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**"
      ]
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ]
    },
    "check-types": {
      "dependsOn": [
        "^check-types"
      ]
    },
    "test:e2e": {
      "dependsOn": [
        "build"
      ]
    },
    "test:unit": {
      "dependsOn": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}